# Server
PORT=4000
NODE_ENV=development

# Supabase (server-side only — use service role key)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Timezone for cron jobs (IANA timezone)
TZ=Europe/Lisbon

# Cron schedule for close-day job (default: 23:55 daily)
CRON_CLOSE_DAY_SCHEDULE=55 23 * * *
