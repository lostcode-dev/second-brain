{
  "name": "second-brain-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "build:bundle": "esbuild src/server.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/server.js --sourcemap",
    "build": "pnpm typecheck && pnpm build:bundle",
    "start": "node dist/server.js",
    "server:bootstrap": "bash ./scripts/server.sh bootstrap",
    "server:deploy": "bash ./scripts/server.sh deploy",
    "server:remote-bootstrap": "bash ./scripts/server.sh remote-bootstrap",
    "server:remote-deploy": "bash ./scripts/server.sh remote-deploy",
    "server:artifact-bootstrap": "bash ./scripts/server.sh bootstrap-artifact",
    "server:artifact-deploy": "bash ./scripts/server.sh deploy-artifact",
    "server:remote-artifact-bootstrap": "bash ./scripts/server.sh remote-artifact-bootstrap",
    "server:remote-artifact-deploy": "bash ./scripts/server.sh remote-artifact-deploy",
    "server:remote-provision": "bash ./scripts/server.sh remote-provision",
    "server:remote-nginx-setup": "bash ./scripts/server.sh remote-nginx-setup",
    "server:remote-nginx-test": "bash ./scripts/server.sh remote-nginx-test",
    "server:remote-status": "bash ./scripts/server.sh remote-status",
    "server:remote-logs": "bash ./scripts/server.sh remote-logs",
    "server:start": "bash ./scripts/server.sh start",
    "server:restart": "bash ./scripts/server.sh restart",
    "server:stop": "bash ./scripts/server.sh stop",
    "server:status": "bash ./scripts/server.sh status",
    "server:logs": "bash ./scripts/server.sh logs",
    "server:list-logs": "bash ./scripts/server.sh list-logs",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "node-cron": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/express": "^5.0.2",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/node": "^22.16.0",
    "@types/node-cron": "^3.0.11",
    "esbuild": "^0.25.10",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0"
  }
}
